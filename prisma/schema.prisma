generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  REVIEWER
  ANNOTATOR
}

enum CompensationType {
  PER_MINUTE
  PER_CASE
}

enum CaseStatus {
  AVAILABLE
  ASSIGNED
  SUBMITTED
  ACCEPTED
  AUDITED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole
  createdAt    DateTime @default(now())

  assignedCases AnnotationCase[] @relation("AnnotatorCases")
  auditedCases  AnnotationCase[] @relation("CaseAuditor")
  reviews         Review[]
  caseNotes       CaseNote[]
  notifications   Notification[]
  availabilityDays AnnotatorAvailability[]
}

model Notification {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String
  annotationCaseId String
  caseLabel        String
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId, readAt])
}

model AnnotationCase {
  id                 String             @id @default(cuid())
  caseId             String             @unique
  redbrickProject    String
  guideId            String?
  guide              Guide?             @relation(fields: [guideId], references: [id], onDelete: SetNull)
  topicId            String?
  topic              Topic?             @relation(fields: [topicId], references: [id], onDelete: SetNull)
  guideline          String
  scopeOfWork        String
  minMinutesPerCase  Int @default(1)
  maxMinutesPerCase  Int
  compensationType   CompensationType
  compensationAmount Float
  annotatorId        String?
  annotator          User?              @relation("AnnotatorCases", fields: [annotatorId], references: [id])
  assignedAt         DateTime?
  completedAt        DateTime?
  annotationMinutes  Int?
  difficultyRating   Int?
  status             CaseStatus         @default(AVAILABLE)
  auditedAt        DateTime?
  auditedById      String?
  auditedBy          User?              @relation("CaseAuditor", fields: [auditedById], references: [id])
  qualityRating      Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  reviews   Review[]
  caseNotes CaseNote[]
}

model Guide {
  id              String          @id @default(cuid())
  title           String
  content         String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  cases           AnnotationCase[]
}

model AnnotatorAvailability {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day            String
  availableHours Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, day])
  @@index([userId, day])
}

model Topic {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  projects TopicProject[]
  cases    AnnotationCase[]
}

model TopicProject {
  id              String   @id @default(cuid())
  topicId         String
  topic           Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  redbrickProject String

  @@unique([topicId, redbrickProject])
  @@index([redbrickProject])
}

model CaseNote {
  id               String         @id @default(cuid())
  annotationCaseId String
  annotationCase   AnnotationCase @relation(fields: [annotationCaseId], references: [id], onDelete: Cascade)
  parentNoteId     String?
  parentNote       CaseNote?      @relation("CaseNoteReplies", fields: [parentNoteId], references: [id], onDelete: Cascade)
  replies          CaseNote[]     @relation("CaseNoteReplies")
  authorId         String
  author           User           @relation(fields: [authorId], references: [id])
  content          String?
  imageData        String?
  imageDataListJson String?
  createdAt        DateTime       @default(now())

  @@index([annotationCaseId])
}

model Review {
  id                 String         @id @default(cuid())
  annotationCaseId   String
  annotationCase     AnnotationCase @relation(fields: [annotationCaseId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        User           @relation(fields: [reviewerId], references: [id])
  decision        String
  comment         String?
  screenshotData  String?
  createdAt       DateTime       @default(now())

  @@index([annotationCaseId])
}
